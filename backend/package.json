{
  "name": "shopassist-ai-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/src/main.js",
    "start:dev": "node --watch --require ts-node/register src/main.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "ts-node --project tsconfig.json scripts/import-sample-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/genai": "^0.12.0",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@supabase/supabase-js": "^2.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "openai": "^4.56.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
